# Hermes Trading System - Single Source of Truth for Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit the .env file to version control.
#
# All components read from this ONE file:
#   - Trading engine (AlpacaBroker, HealthSupervisor, etc.)
#   - Hermes Agentic submodule (external/hermes-agentic/.env is hardlinked here)

# --- Execution Engine Mode ---
# Options: paper, live, historical
HERMES_MODE=paper

# --- Alpaca Paper API Keys ---
# Get these from your Alpaca dashboard (https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# --- Interactive Brokers (Future Integration) ---
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# --- Hermes Agentic (External Research Agent / LLM Intelligence Layer) ---
# Configure at least ONE LLM provider below.
# The hermes-agentic submodule reads this via hardlink to external/hermes-agentic/.env
#
# OpenRouter (recommended - single key, 200+ models):
# Get your key at: https://openrouter.ai/keys
# HERMES_OPENROUTER_API_KEY=your_openrouter_key_here
#
# Alternative: Google AI Studio / Gemini
# Get your key at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your_google_key_here
#
# Alternative: Xiaomi MiMo
# Get your key at: https://platform.xiaomimimo.com
# XIAOMI_API_KEY=your_key_here
